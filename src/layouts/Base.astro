---
import '../styles/tokens.css';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  jsonLd?: object | object[];
  ogImage?: string;
}

const { title, description, canonical, jsonLd, ogImage } = Astro.props;
const canonicalURL = canonical ?? new URL(Astro.url.pathname, Astro.site).href;
const fullTitle = title.includes('fluyeporlaweb') ? title : `${title} - fluyeporlaweb`;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="fluyeporlaweb" />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <meta name="twitter:card" content="summary" />
    <meta name="twitter:site" content="@fluyeporlaweb" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />

    {jsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(Array.isArray(jsonLd) ? jsonLd : [jsonLd])} />
    )}

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-KKNB7N5W3P"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-KKNB7N5W3P');
    </script>
  </head>
  <body>
    <header class="site-header">
      <nav class="site-nav">
        <a href="/" class="site-logo">fluyeporlaweb</a>
        <ul class="nav-links">
          <li><a href="/directorio">Directorio</a></li>
          <li><a href="/blog">Blog</a></li>
          <li class="nav-cta"><a href="/enviar">Enviar herramienta</a></li>
        </ul>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="footer-inner">
        <div class="footer-top">
          <nav class="footer-links" aria-label="Navegación legal">
            <a href="/directorio">Directorio</a>
            <a href="/blog">Blog</a>
            <a href="/sobre">Sobre</a>
            <a href="/enviar">Enviar herramienta</a>
            <a href="/legal/privacidad">Privacidad</a>
            <a href="/legal/cookies">Cookies</a>
            <a href="/legal/terminos">Términos</a>
            <a href="/legal/contacto">Contacto</a>
          </nav>
        </div>
        <div class="footer-bottom">
          <p class="footer-copy">
            © 2026 fluyeporlaweb - Hecho por
            <a href="https://x.com/fluyeporlaweb" target="_blank" rel="noopener noreferrer">Pablo Navarro</a>
          </p>
          <nav class="footer-social" aria-label="Redes sociales">
            <a href="https://x.com/fluyeporlaweb" target="_blank" rel="noopener noreferrer" aria-label="X (Twitter)">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.734-8.835L1.254 2.25H8.08l4.713 5.936zM17.083 20.25h1.833L7.084 4.126H5.117z"/>
              </svg>
              <span>@fluyeporlaweb</span>
            </a>
            <a href="https://t.me/fluyeporlaweb" target="_blank" rel="noopener noreferrer" aria-label="Telegram">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.96 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/>
              </svg>
              <span>Telegram</span>
            </a>
          </nav>
        </div>
      </div>
    </footer>

    <div class="mobile-cta-bar">
      <a href="/enviar">Enviar herramienta</a>
    </div>
  </body>
</html>

<style>
  .footer-top {
    padding-bottom: var(--space-4);
    border-bottom: 1px solid var(--color-border);
    margin-bottom: var(--space-4);
  }

  .footer-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-3);
  }

  .footer-social {
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }

  .footer-social a {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--color-text-2);
    text-decoration: none;
    transition: color 0.15s;
  }

  .footer-social a:hover {
    color: var(--color-brand);
  }

  .footer-copy a {
    color: var(--color-text-2);
  }

  .footer-copy a:hover {
    color: var(--color-brand);
  }
</style>
