---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog', (e) => !e.data.draft);
const sorted = posts.sort((a, b) => b.data.pubDate.localeCompare(a.data.pubDate));
---

<Base
  title="Blog - fluyeporlaweb"
  description="Artículos sobre herramientas open source, MCPs, automatización e IA para developers en español."
>
  <div class="blog-page container">
    <header class="blog-header">
      <h1 class="blog-header__title">Blog</h1>
      <p class="blog-header__desc">
        Herramientas, MCPs, automatización, IA. Sin hype, con criterio.
      </p>
    </header>

    {sorted.length > 0 ? (
      <ul class="post-list">
        {sorted.map(post => {
          const slugClean = post.id.replace(/\.mdx?$/, '');
          const date = new Date(post.data.pubDate).toLocaleDateString('es-ES', {
            year: 'numeric', month: 'long', day: 'numeric',
          });
          return (
            <li class="post-item">
              <article>
                <time class="post-item__date" datetime={post.data.pubDate}>{date}</time>
                <h2 class="post-item__title">
                  <a href={`/blog/${slugClean}`}>{post.data.title}</a>
                </h2>
                <p class="post-item__desc">{post.data.description}</p>
                {post.data.tags.length > 0 && (
                  <div class="post-item__tags">
                    {post.data.tags.map(tag => (
                      <span class="post-item__tag">{tag}</span>
                    ))}
                  </div>
                )}
              </article>
            </li>
          );
        })}
      </ul>
    ) : (
      <div class="blog-empty">
        <p>Los artículos están en camino.</p>
      </div>
    )}
  </div>
</Base>

<style>
  .blog-page {
    padding-top: var(--space-8);
    padding-bottom: var(--space-16);
    max-width: 760px;
  }

  .blog-header {
    margin-bottom: var(--space-10);
  }

  .blog-header__title {
    font-size: var(--text-4xl);
    letter-spacing: -0.02em;
    margin-bottom: var(--space-3);
  }

  .blog-header__desc {
    font-size: var(--text-lg);
    color: var(--color-text-2);
  }

  .post-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .post-item {
    padding: var(--space-6) 0;
    border-bottom: 1px solid var(--color-border);
  }

  .post-item:first-child {
    border-top: 1px solid var(--color-border);
  }

  .post-item__date {
    display: block;
    font-size: var(--text-sm);
    color: var(--color-text-3);
    margin-bottom: var(--space-2);
  }

  .post-item__title {
    font-size: var(--text-xl);
    margin-bottom: var(--space-2);
    letter-spacing: -0.01em;
  }

  .post-item__title a {
    color: var(--color-text);
  }

  .post-item__title a:hover {
    color: var(--color-brand);
    text-decoration: none;
  }

  .post-item__desc {
    font-size: var(--text-base);
    color: var(--color-text-2);
    line-height: 1.5;
    margin-bottom: var(--space-3);
  }

  .post-item__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .post-item__tag {
    font-size: var(--text-xs);
    padding: 0.15em 0.5em;
    background: var(--color-bg-3);
    border-radius: var(--radius-sm);
    color: var(--color-text-2);
  }

  .blog-empty {
    padding: var(--space-16) 0;
    color: var(--color-text-2);
    text-align: center;
  }
</style>
