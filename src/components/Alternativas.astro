---
interface Props {
  replaces: string[];
  replaces_cost?: string;
}

const { replaces, replaces_cost } = Astro.props;
---

{replaces.length > 0 && (
  <aside class="alternativas" aria-labelledby="alternativas-title">
    <h3 id="alternativas-title" class="alternativas__title">Sustituye a</h3>
    <ul class="alternativas__list">
      {replaces.map(name => (
        <li class="alternativas__item">
          <span class="alternativas__name">{name}</span>
        </li>
      ))}
    </ul>
    {replaces_cost && (
      <p class="alternativas__cost">
        Ahorro potencial: <strong>{replaces_cost}</strong>
      </p>
    )}
  </aside>
)}

<style>
  .alternativas {
    background: var(--color-bg-2);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: var(--space-4);
  }

  .alternativas__title {
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--color-text-2);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: var(--space-3);
  }

  .alternativas__list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    margin-bottom: var(--space-3);
  }

  .alternativas__item {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .alternativas__item::before {
    content: '✕';
    color: var(--color-error);
    font-size: var(--text-xs);
    font-weight: 700;
    flex-shrink: 0;
  }

  .alternativas__name {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-text);
  }

  .alternativas__cost {
    font-size: var(--text-sm);
    color: var(--color-text-2);
    padding-top: var(--space-3);
    border-top: 1px solid var(--color-border);
    margin-top: var(--space-1);
  }

  .alternativas__cost strong {
    color: var(--color-brand);
  }
</style>
