---
import { getCollection } from 'astro:content';
import HerramientaCard from './HerramientaCard.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  currentSlug: string;
  tags: string[];
  limit?: number;
}

const { currentSlug, tags, limit = 3 } = Astro.props;

const all = await getCollection('herramientas', (e) =>
  e.data.status === 'activo' && e.data.slug !== currentSlug
);

const related = all
  .map(tool => ({
    tool,
    shared: tool.data.tags.filter(t => tags.includes(t)).length,
  }))
  .filter(({ shared }) => shared > 0)
  .sort((a, b) => b.shared - a.shared)
  .slice(0, limit)
  .map(({ tool }) => tool);
---

{related.length > 0 && (
  <section class="relacionadas" aria-labelledby="relacionadas-title">
    <h2 id="relacionadas-title" class="relacionadas__title">Herramientas relacionadas</h2>
    <div class="tools-grid">
      {related.map(tool => <HerramientaCard tool={tool} />)}
    </div>
  </section>
)}

<style>
  .relacionadas {
    margin-top: var(--space-12);
  }

  .relacionadas__title {
    font-size: var(--text-xl);
    margin-bottom: var(--space-6);
    padding-bottom: var(--space-2);
    border-bottom: 1px solid var(--color-border);
  }
</style>
